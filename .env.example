# ===========================================
# LeadGenius Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL="postgresql://user:password@localhost:5432/leadgenius"

# ===========================================
# AI PROVIDERS (Choose one or more)
# ===========================================
# OpenAI (Paid - https://platform.openai.com)
OPENAI_API_KEY="sk-..."

# Anthropic Claude (Paid - https://console.anthropic.com)
ANTHROPIC_API_KEY="sk-ant-..."

# GLM (FREE - https://z.ai) ⭐ Recommended for free tier
GLM_API_KEY="..."

# Groq (Free tier - https://console.groq.com)
GROQ_API_KEY="gsk_..."

# DeepSeek (Free tier - https://platform.deepseek.com)
DEEPSEEK_API_KEY="sk-..."

# Kimi (https://moonshot.ai)
KIMI_API_KEY="sk-..."

# MiniMax (https://minimaxi.com)
MINIMAX_API_KEY="..."

# Ollama (Local - https://ollama.ai)
OLLAMA_BASE_URL="http://localhost:11434"

# ===========================================
# EMAIL PROVIDERS (Choose one)
# ===========================================

# Option 1: Gmail SMTP (Easiest)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-16-char-app-password"

# Option 2: Resend (Better for production)
RESEND_API_KEY="re_..."

# Option 3: Custom SMTP
# SMTP_HOST="mail.your-domain.com"
# SMTP_PORT="465"
# SMTP_SECURE="true"
# SMTP_USER="noreply@your-domain.com"
# SMTP_PASS="your-password"

# ===========================================
# TELEGRAM BOT (Optional)
# ===========================================
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN="123456789:ABCdefGHIjklMNOpqrsTUVwxyz"

# Get your Chat ID via @userinfobot on Telegram
TELEGRAM_CHAT_ID="123456789"

# ===========================================
# GOOGLE OAUTH (For Gmail integration)
# ===========================================
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3001/auth/gmail/callback"

# ===========================================
# APPLICATION SETTINGS
# ===========================================
PORT="3001"
NODE_ENV="development"

# ===========================================
# REDIS (Optional - for background jobs)
# ===========================================
REDIS_URL="redis://localhost:6379"
